<?xml version="1.0" encoding="utf-8"?><androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 1. The PROCESSED View (Background) -->
    <ImageView
        android:id="@+id/ivDebugFrame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter" />

    <!-- 2. The RAW View (Small Overlay) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 3. Dimension Text (Now stacked above the RadioGroup) -->
    <TextView
        android:id="@+id/tvDimensions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Detecting..."
        android:textColor="#00FF00"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/rgGridLock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 4. Grid Lock Selection (Stacked above Threshold Label) -->
    <RadioGroup
        android:id="@+id/rgGridLock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#80000000"
        android:padding="4dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/tvThresholdValue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioButton android:id="@+id/rbAuto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Auto" android:textColor="#FFFFFF" android:checked="true" android:buttonTint="#FFFFFF"/>
        <RadioButton android:id="@+id/rb9x9" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="9x9" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF"/>
        <RadioButton android:id="@+id/rb16x16" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="16x16" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF"/>
        <RadioButton android:id="@+id/rb25x25" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25x25" android:textColor="#FFFFFF" android:buttonTint="#FFFFFF"/>
    </RadioGroup>

    <!-- 5. Threshold Label (Stacked above SeekBar) -->
    <TextView
        android:id="@+id/tvThresholdValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Threshold: 30"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@+id/thresholdSeekBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 6. SeekBar (Stacked above Capture Button) -->
    <SeekBar
        android:id="@+id/thresholdSeekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="16dp"
        android:max="255"
        android:progress="30"
        app:layout_constraintBottom_toTopOf="@+id/btnCapture"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 7. Capture Button (Anchor at bottom) -->
    <Button
        android:id="@+id/btnCapture"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="Capture"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>